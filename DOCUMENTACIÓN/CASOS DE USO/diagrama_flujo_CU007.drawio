        <!-- ===== TÍTULO ===== -->
        <mxCell id="title" value="CU-007 – Gestión de Producción&#xa;Actor: Administrador  |  RF-013, RF-014, RF-015" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#003366;" vertex="1" parent="1">
          <mxGeometry x="234" y="20" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- ===== INICIO ===== -->
        <mxCell id="start" value="INICIO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#003366;fontStyle=1;fontSize=13;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="484" y="90" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ===== PASO 1 ===== -->
        <mxCell id="step1" value="&lt;b&gt;PASO 1&lt;/b&gt;&#xa;El administrador accede al módulo&#xa;de Gestión de Producción&#xa;[RF-013]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="434" y="180" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- ===== PASO 2 ===== -->
        <mxCell id="step2" value="&lt;b&gt;PASO 2&lt;/b&gt;&#xa;Crea nueva orden de producción:&#xa;cliente, producto, materiales,&#xa;cantidad y fecha límite&#xa;[RF-013]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="434" y="290" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- ===== DECISIÓN 1 ===== -->
        <mxCell id="dec1" value="¿Datos de la&#xa;orden válidos?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="484" y="410" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- ALT 1 -->
        <mxCell id="alt1" value="&lt;b&gt;ALT 1&lt;/b&gt;&#xa;Datos incompletos o inválidos →&#xa;el sistema muestra error y&#xa;solicita corrección" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="134" y="415" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- ===== PASO 3 ===== -->
        <mxCell id="step3" value="&lt;b&gt;PASO 3&lt;/b&gt;&#xa;Asigna la orden a un operario&#xa;disponible, define prioridad&#xa;[RF-013] [RF-014]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="434" y="550" width="300" height="75" as="geometry" />
        </mxCell>

        <!-- ===== DECISIÓN 2 ===== -->
        <mxCell id="dec2" value="¿Operario&#xa;disponible?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="484" y="670" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- ALT 2 -->
        <mxCell id="alt2" value="&lt;b&gt;ALT 2&lt;/b&gt;&#xa;Reasignar a otro operario&#xa;o dejar en estado Pendiente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="134" y="680" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- ===== PASO 4 ===== -->
        <mxCell id="step4" value="&lt;b&gt;PASO 4&lt;/b&gt;&#xa;El sistema registra la orden con&#xa;estado &quot;En Proceso&quot; y notifica&#xa;al operario asignado&#xa;[RF-013] [RF-014]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="434" y="810" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- ===== PASO 5 ===== -->
        <mxCell id="step5" value="&lt;b&gt;PASO 5&lt;/b&gt;&#xa;El administrador monitorea avance:&#xa;progreso porcentual, unidades&#xa;completadas y barra de estado&#xa;[RF-014]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="434" y="935" width="300" height="85" as="geometry" />
        </mxCell>

        <!-- ===== DECISIÓN 3 ===== -->
        <mxCell id="dec3" value="¿Se reporta&#xa;alguna incidencia?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="484" y="1065" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- ALT/EXC 3 -->
        <mxCell id="exc3" value="&lt;b&gt;EXC / ALT 3&lt;/b&gt;&#xa;Se registra la incidencia&#xa;(retraso, material faltante).&#xa;Administrador: reasigna,&#xa;pausa o escala al cliente&#xa;[RF-015]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="134" y="1060" width="250" height="100" as="geometry" />
        </mxCell>

        <!-- ===== DECISIÓN 4 ===== -->
        <mxCell id="dec4" value="¿Orden&#xa;completada?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="484" y="1205" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- ALT 4 -->
        <mxCell id="alt4" value="&lt;b&gt;ALT 4&lt;/b&gt;&#xa;Continúa ciclo de monitoreo&#xa;→ regresa al Paso 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="134" y="1215" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- ===== PASO 6 ===== -->
        <mxCell id="step6" value="&lt;b&gt;PASO 6&lt;/b&gt;&#xa;El sistema actualiza la orden a&#xa;&quot;Completada&quot; automáticamente&#xa;al alcanzar las unidades totales&#xa;[RF-014]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=10;" vertex="1" parent="1">
