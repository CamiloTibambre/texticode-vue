JWT_SECRET=cambia_este_secreto_seguro
JWT_EXPIRES=8h

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=texticode

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google OAuth 2.0 / Calendar API
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
